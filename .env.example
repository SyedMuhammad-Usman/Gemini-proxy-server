# ── Gemini Direct API (used by main.py) ──────────────────────────────────────
GEMINI_API_KEY=your_real_gemini_api_key_here

# ── Vertex AI (used by main_vertex.py) ───────────────────────────────────────
VERTEX_PROJECT=your-gcp-project-id
VERTEX_LOCATION=us-central1
VERTEX_MODEL=gemini-2.0-flash-001

# ── Friend access control (shared by both versions) ──────────────────────────
# Key you share with your friend — keep this secret too!
FRIEND_API_KEY=change-me-to-something-random

# ISO 8601 date after which the key stops working (leave blank for no expiry)
FRIEND_EXPIRES_AT=2026-12-31T23:59:59

# Maximum number of requests allowed (0 = unlimited)
FRIEND_REQUEST_LIMIT=500
